CONFLUENCE_IMAGE=atlassian/confluence:10.2.13
# Concrete minor pin (not the floating postgres:15 head) for a reproducible disposable test DB.
POSTGRES_IMAGE=postgres:15.18
CONFLUENCE_PORT=8090
# Host interface the Confluence port is published on. Defaults to loopback because this test instance
# is deliberately permissive (admin/admin, Basic-auth force-allowed, signature check off). Set to
# 0.0.0.0 only to reach it from another machine on a trusted network.
CONFLUENCE_BIND=127.0.0.1
# Confluence 10.2 is heavier than 9.2; give it more heap (host should have >=6 GB free).
JVM_MINIMUM_MEMORY=1024m
JVM_MAXIMUM_MEMORY=2048m
# Container memory hard limit (cgroup). Must stay >= JVM_MAXIMUM_MEMORY + ~1.2g of non-heap headroom
# (metaspace, code cache, thread stacks, direct buffers) or the JVM gets OOMKilled. If you raise
# JVM_MAXIMUM_MEMORY above, raise this in lockstep.
CONFLUENCE_MEM_LIMIT=3g
POSTGRES_PASSWORD=confluence
